{
  "schema_version": 1,
  "name": "claude",
  "pack_type": "agent",
  "description": "Sandbox awareness plugin for Claude Code. Provides diagnostics on permission denials and assists with profile authoring.",
  "license": "Apache-2.0",
  "platforms": ["macos", "linux"],
  "min_nono_version": "0.29.0",
  "artifacts": [
    {
      "type": "plugin",
      "path": ".claude-plugin/plugin.json"
    },
    {
      "type": "plugin",
      "path": "skills/nono-sandbox/SKILL.md"
    },
    {
      "type": "plugin",
      "path": "hooks/hooks.json"
    },
    {
      "type": "plugin",
      "path": "bin/nono-hook.sh"
    },
    {
      "type": "plugin",
      "path": "bin/nono-hook-bash.sh"
    }
  ]
}
